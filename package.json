{
  "name": "command-neural-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "concurrently -n web,api \"pnpm --filter console-web dev\" \"pnpm --filter command-api start:dev\"",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "format": "prettier --write .",
    "verify:callback-signature": "node infrastructure/scripts/verify-callback-signature.mjs",
    "test:core-command-flow": "bash infrastructure/scripts/core-command-flow-smoke.sh",
    "test:understanding-idempotency": "bash infrastructure/scripts/understanding-idempotency-smoke.sh",
    "test:propagation-idempotency": "bash infrastructure/scripts/propagation-idempotency-smoke.sh",
    "test:timeout-recovery": "bash infrastructure/scripts/timeout-recovery-smoke.sh",
    "test:execution-feedback-idempotency": "bash infrastructure/scripts/execution-feedback-idempotency-smoke.sh",
    "test:feedback-aggregation-idempotency": "bash infrastructure/scripts/feedback-aggregation-idempotency-smoke.sh",
    "test:closure-state-machine": "bash infrastructure/scripts/closure-state-machine-smoke.sh",
    "test:next-round-creation": "bash infrastructure/scripts/next-round-creation-smoke.sh",
    "test:audit-timeline-pagination": "bash infrastructure/scripts/audit-timeline-pagination-smoke.sh",
    "test:node-ops-recovery": "bash infrastructure/scripts/node-ops-recovery-smoke.sh",
    "test:node-scale-1000": "bash infrastructure/scripts/node-scale-1000-smoke.sh",
    "test:scalability-baseline": "bash infrastructure/scripts/scalability-baseline-smoke.sh",
    "test:external-metrics-export": "bash infrastructure/scripts/external-metrics-export-smoke.sh",
    "test:full-drill": "bash infrastructure/scripts/full-regression-drill.sh",
    "report:release-acceptance": "bash infrastructure/scripts/release-acceptance-report.sh",
    "report:external-metrics-snapshot": "bash infrastructure/scripts/external-metrics-snapshot.sh",
    "gate:release": "bash infrastructure/scripts/gate-release.sh",
    "gate:release:fast": "bash infrastructure/scripts/gate-release.sh fast",
    "gate:release:strict": "bash infrastructure/scripts/gate-release.sh strict",
    "gate:release:strict:1000": "RUN_NODE_SCALE_1000=1 bash infrastructure/scripts/gate-release.sh strict",
    "gate:release:precheck": "bash infrastructure/scripts/gate-release-pass-precheck.sh",
    "e2e:external-integration": "bash infrastructure/scripts/external-integration-e2e.sh",
    "regression:db-persistence": "bash infrastructure/scripts/db-persistence-regression.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
